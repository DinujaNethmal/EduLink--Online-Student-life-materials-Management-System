							"mode": "raw",
							"raw": "{\n    \"name\": \"Arduino Uno\",\n    \"price\": 1200,\n    \"description\": \"Original Arduino Uno for projects\",\n    \"category\": \"Electronics\",\n    \"condition\": \"New\",\n    \"image\": \"https://example.com/image.jpg\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/products",
							"host": [
