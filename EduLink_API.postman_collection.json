							"path": [
								"api",
								"quiz"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Quiz",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Sample Quiz\",\n    \"description\": \"This is a test quiz\",\n    \"category\": \"General\",\n    \"timeLimit\": 30\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/quiz/create",
