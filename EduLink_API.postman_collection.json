				{
					"name": "Get Quiz By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/quiz/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"quiz",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "QUIZ_ID_HERE"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Products",
